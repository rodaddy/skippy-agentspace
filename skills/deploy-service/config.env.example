# deploy-service configuration -- DEPLOY_* variables for your infrastructure
# Copy to config.env and fill in your values.
# config.env is gitignored -- never commit real values.

# Proxmox host IP (e.g., 10.0.1.1)
DEPLOY_SERVER_IP=""

# Wildcard SSL domain (e.g., example.com)
DEPLOY_DOMAIN=""

# VMID of nginx proxy container (e.g., 100)
DEPLOY_PROXY_VMID=""

# IP of proxy container for DNS entries (e.g., 10.0.2.100)
DEPLOY_PROXY_IP=""

# First network prefix, first 3 octets (e.g., 10.0.1)
DEPLOY_NET1=""

# Second network prefix, first 3 octets (e.g., 10.0.2)
DEPLOY_NET2=""

# Default gateway IP (e.g., 10.0.1.1)
DEPLOY_GATEWAY=""

# Space-separated DNS server VMIDs (e.g., "101 102")
DEPLOY_DNS_VMIDS=""

# Vaultwarden instance URL without protocol (e.g., vault.example.com)
DEPLOY_VAULTWARDEN_URL=""
