      "event": "UserPromptSubmit",
      "matcher": null,
      "script": "law-13-no-silent-autopilot.ts",
      "blocking": true
    },
    {
      "id": "law-14",
      "law": 14,
      "name": "Network Share Protocol",
      "description": "Enforce SMB/network share access protocols",
      "event": "PreToolUse",
      "matcher": "Bash",
      "script": "law-14-network-share-protocol.ts",
      "blocking": true
    },
    {
      "id": "law-15",
      "law": 15,
      "name": "No LiteLLM Self-Surgery",
      "description": "Block direct LiteLLM config modifications",
      "event": "PreToolUse",
      "matcher": "Bash",
      "script": "law-15-no-litellm-self-surgery.ts",
      "blocking": true
